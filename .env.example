APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=keplererp
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# WhatsApp Cloud API (Meta) — SRS §17. Enable "WhatsApp notifications" on Company setup, then set:
# WHATSAPP_DRIVER=cloud
# WABA_PHONE_NUMBER_ID=951610754710542
# WABA_ACCESS_TOKEN=
# WABA_GRAPH_VERSION=v25.0
# POST URL pattern: https://graph.facebook.com/v25.0/{WABA_PHONE_NUMBER_ID}/messages
# Optional: WHATSAPP_TEMPLATE_LOCALE=en  WHATSAPP_DEFAULT_CC=91
WHATSAPP_DRIVER=log

# GST e-Invoice (IRP) — set EINVOICE_DRIVER=nic and GSP/NIC credentials for live IRN
# EINVOICE_DRIVER=log
# EINVOICE_NIC_BASE_URL=https://your-gsp.example.com/api
# EINVOICE_NIC_AUTH_PATH=/authenticate
# EINVOICE_NIC_GENERATE_PATH=/einvoice/generate
# EINVOICE_NIC_USERNAME=
# EINVOICE_NIC_PASSWORD=
# EINVOICE_NIC_CLIENT_ID=
# EINVOICE_NIC_CLIENT_SECRET=
# EINVOICE_NIC_GSTIN=24AAAAA0000A1Z5

# GST e-Way bill — set EWAY_DRIVER=nic for live e-Way (enable eway on Company setup)
# EWAY_DRIVER=log
# EWAY_NIC_BASE_URL=https://your-gsp.example.com/api
# EWAY_NIC_AUTH_PATH=/authenticate
# EWAY_NIC_GENERATE_PATH=/ewaybill/generate
# EWAY_NIC_USERNAME=
# EWAY_NIC_PASSWORD=
# EWAY_NIC_CLIENT_ID=
# EWAY_NIC_CLIENT_SECRET=
# EWAY_NIC_GSTIN=24AAAAA0000A1Z5

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
